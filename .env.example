# Theme Sector Radar environment example
# Copy to .env for local use. Do not commit .env.

# Optional local data service. Default used by the code when unset:
MARKET_DATA_SERVICE_URL=http://127.0.0.1:8000

# Optional local StockDB settings for users who have StockDB installed.
STOCKDB_HOST=127.0.0.1
STOCKDB_PORT=7899
STOCKDB_SDK_PATH=
STOCKDB_EXE_PATH=

# Optional LLM settings for downstream agent integrations.
# Sample mode does not require any API key.
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=
AIHF_LLM_MODEL=
FINANCIAL_DATASETS_API_KEY=
